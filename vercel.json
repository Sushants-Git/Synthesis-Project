{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/openai/:path*", "destination": "/api/openai" },
    { "source": "/api/claude/:path*", "destination": "/api/claude" },
    { "source": "/api/twitter/:path*", "destination": "/api/twitter" },
    { "source": "/api/github/:path*", "destination": "/api/github" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
